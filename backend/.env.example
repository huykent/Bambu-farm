# Server Configuration
PORT=8080
ENV=development

# Database Configuration
# This maps to the docker-compose database credentials
DATABASE_URL=postgres://bambu:bambupass@localhost:5432/bambudb?sslmode=disable
# If running purely inside docker-compose without exposing ports, use this instead:
# DATABASE_URL=postgres://bambu:bambupass@db:5432/bambudb?sslmode=disable

# Redis Configuration 
# Maps to the docker-compose redis credentials
REDIS_HOST=localhost
# REDIS_HOST=redis (if running fully inside docker-compose)
REDIS_PORT=6379

# Authentication Secrets
# CHANGE THIS TO A RANDOM SECURE STRING IN PRODUCTION
JWT_SECRET=super_secret_bambu_farm_key_replace_me

# Alert System Configurations (Optional)
# TELEGRAM_BOT_TOKEN=
# TELEGRAM_CHAT_ID=
# ALERT_EMAIL=admin@bambufarm.local
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your_email@gmail.com
# SMTP_PASS=your_app_password
